# SOCaaS multi-node lab defaults.
# Copy to env/socaas.env and edit only when your lab IPs, username, password, or SSH key differ.

export SOCAAS_VM_USER="k8s-user"
export SOCAAS_VM_PASSWORD="k8s-password"
export SOCAAS_SSH_KEY="$HOME/.ssh/id_ed25519"
export SOCAAS_SSH_OPTS="-o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$HOME/.ssh/known_hosts"

export SOCAAS_BASE_DIR="/srv/socaas"
export SOCAAS_REPO_DIR="/srv/socaas/repo"
export SOCAAS_LIBVIRT_IMAGES_DIR="/srv/socaas/libvirt/images"
export SOCAAS_LIBVIRT_CLOUD_IMAGE_DIR="/var/lib/libvirt/images/socaas"
export SOCAAS_LIBVIRT_CLOUD_IMAGE_PATH="${SOCAAS_LIBVIRT_CLOUD_IMAGE_DIR}/ubuntu-22.04-server-cloudimg-amd64.img"
export SOCAAS_DOWNLOADS_DIR="/srv/socaas/downloads"
export SOCAAS_GENERATED_DIR="/srv/socaas/generated"
export SOCAAS_BACKUPS_DIR="/srv/socaas/backups"
export SOCAAS_LOGS_DIR="/srv/socaas/logs"
export SOCAAS_RUNTIME_DIR="/srv/socaas/runtime"
export SOCAAS_VM_STORAGE_DIR="/srv/socaas"
export SOCAAS_MIN_FREE_GB="220"

export SOCAAS_HOST_BRIDGE="virbr0"
export SOCAAS_HOST_BRIDGE_IP="192.168.122.1"
export SOCAAS_NETWORK_CIDR="192.168.122.0/24"
export SOCAAS_GATEWAY_IP="192.168.122.1"

export SOCAAS_MASTER_NAME="k8s-master"
export SOCAAS_WORKER1_NAME="k8s-worker1"
export SOCAAS_WORKER2_NAME="k8s-worker2"
export SOCAAS_MASTER_IP="192.168.122.10"
export SOCAAS_WORKER1_IP="192.168.122.11"
export SOCAAS_WORKER2_IP="192.168.122.12"

export SOCAAS_MASTER_MAC="52:54:00:aa:10:10"
export SOCAAS_WORKER1_MAC="52:54:00:aa:10:11"
export SOCAAS_WORKER2_MAC="52:54:00:aa:10:12"

export SOCAAS_MASTER_RAM_MB="4096"
export SOCAAS_MASTER_VCPU="2"
export SOCAAS_MASTER_DISK_GB="50"
export SOCAAS_WORKER_RAM_MB="8192"
export SOCAAS_WORKER_VCPU="4"
export SOCAAS_WORKER_DISK_GB="120"
export SOCAAS_WORKER1_DISK_GB="${SOCAAS_WORKER_DISK_GB}"
export SOCAAS_WORKER2_DISK_GB="${SOCAAS_WORKER_DISK_GB}"

export SOCAAS_POD_CIDR="10.244.0.0/16"
export SOCAAS_SERVICE_CIDR="10.96.0.0/12"
export SOCAAS_K8S_MINOR="v1.28"
export SOCAAS_CALICO_VERSION="v3.28.5"

export SOCAAS_HELM_RELEASE="socaas"
export SOCAAS_HELM_NAMESPACE="socaas-system"
export SOCAAS_SIEM_NAMESPACE="socaas-siem"
export SOCAAS_SOAR_NAMESPACE="socaas-soar"
export SOCAAS_IR_NAMESPACE="socaas-thehive"

# UI and integration ports exposed on the Parrot host through HAProxy.
export SOCAAS_WAZUH_AGENT_TCP_PORT="1514"
export SOCAAS_WAZUH_ENROLL_PORT="1515"
export SOCAAS_WAZUH_API_PORT="55000"
export SOCAAS_WAZUH_MANAGER_COMPAT_PORT="30000"
export SOCAAS_WAZUH_DASHBOARD_PORT="30002"
export SOCAAS_SHUFFLE_UI_PORT="30080"
export SOCAAS_THEHIVE_UI_PORT="30900"
export SOCAAS_HAPROXY_STATS_PORT="8404"

# Default lab credentials. Change after the first successful deployment.
export SOCAAS_WAZUH_ADMIN_USER="admin"
export SOCAAS_WAZUH_ADMIN_PASSWORD="SecretPassword"
export SOCAAS_SHUFFLE_ADMIN_EMAIL="admin@socaas.local"
export SOCAAS_SHUFFLE_ADMIN_PASSWORD="S0CaaS-Shuffle-2026!"
export SOCAAS_THEHIVE_SECRET="S0CaaS-TheHive-Secret-2026-ChangeMe"
export SOCAAS_MINIO_ACCESS_KEY="thehiveadmin"
export SOCAAS_MINIO_SECRET_KEY="ChangeThisMinIOPassword!"
export SOCAAS_PIPELINE_SHARED_SECRET="S0CaaS-Wazuh-Webhook-2026"

# Optional: after you create a native Shuffle webhook in the UI, set this to its URL.
# The pipeline gateway will forward to it and still keep deterministic lab logging.
export SOCAAS_NATIVE_SHUFFLE_WEBHOOK_URL=""
